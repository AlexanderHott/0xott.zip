<div id="example4-app"></div>

<script>
  type ComponentChild =
    | object
    | string
    | number
    | bigint
    | boolean
    | null
    | undefined;

  // also commonly called `createElement`
  function h(
    tagName: keyof HTMLElementTagNameMap,
    attributes: Record<string, unknown>,
    ...children: ComponentChild[]
  ) {
    const element = document.createElement(tagName);
    for (const [key, val] of Object.entries(attributes)) {
      if (key.startsWith("on")) {
        element.addEventListener(key.slice(2).toLowerCase(), val as any);
      } else if (key === "className") {
        element.className = String(val);
      } else {
        element.setAttribute(key, String(val));
      }
    }

    children
      ?.filter((child) => Boolean(child))
      .forEach((child) => {
        element.appendChild(
          child instanceof Node
            ? child
            : document.createTextNode(String(child)),
        );
      });

    return element;
  }

  async function sleep(ms: number) {
    return new Promise((res) => setTimeout(() => res(ms), ms));
  }

  async function divide(a: number, b: number) {
    const delay = 200 + Math.random() * 2000;
    await sleep(delay);

    return a / b;
  }

  let n = 1;
  let version = 0;
  const root = document.getElementById("example4-app")!;
  let prev: HTMLElement | undefined = undefined;

  function mount(app: HTMLElement) {
    if (prev) {
      root.replaceChild(app, prev);
    } else {
      root.appendChild(app);
    }
    prev = app;
  }

  function appComponent(currentN: number, ...content: ComponentChild[]) {
    return h(
      "div",
      {},
      h("div", {}, `n = ${currentN}`),
      h(
        "button",
        {
          onClick: () => {
            n += 1;
            update();
          },
        },
        "increment",
      ),
      ...content,
    );
  }

  function update() {
    const currentN = n;
    const v = ++version;
    const items = Array.from({ length: 5 }, (_, i) => i + 1);

    mount(appComponent(currentN, h("div", {}, "loading...")));

    Promise.all(items.map((i) => divide(i, currentN))).then((results) => {
      if (v !== version) return;

      mount(
        appComponent(
          currentN,
          ...results.map((result, i) =>
            h("div", {}, `${items[i]} / ${currentN} = ${result.toFixed(3)}`),
          ),
        ),
      );
    });
  }

  update();
</script>
